@page "/currencies/details"
@attribute [ExcludeFromInteractiveRouting]
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage PageTitleText="Currency Details" EntityTitle="Currency" BasePath="/currencies"Entity="currency"EntityId="currency?.Id" />

@code {
    private Currency currency;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        currency = await repo.GetAsync(Id);
        if (currency is null) NavigationManager.NotFound();
    }
}
