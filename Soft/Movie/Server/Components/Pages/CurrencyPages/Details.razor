@page "/currencies/details"
@attribute [ExcludeFromInteractiveRouting]
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage PageTitleText="Currency Details" EntityTitle="Currency" BasePath="/currencies"Entity="item"EntityId="item?.Id" />

@code {
    private Currency item;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
}
