@page "/currencies/delete"
@attribute [ExcludeFromInteractiveRouting]
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Currency" EntityTitle="Currency" BasePath="/currencies" Entity="item" OnValidSubmit="delete" />

@code {
    private Currency item;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
    private async Task delete()
    {
        await repo.DeleteAsync(item!.Id);
        NavigationManager.NavigateTo("/currencies");
    }
}
