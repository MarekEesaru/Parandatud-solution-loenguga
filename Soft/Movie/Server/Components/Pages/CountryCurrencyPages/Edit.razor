@page "/countrycurrencies/edit"
@attribute [ExcludeFromInteractiveRouting]
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage PageTitleText="Edit Country Currency" EntityTitle="Country Currency" Entity="countryCurrency" BasePath="/countrycurrencies" EntityId="@Id" OnValidSubmit="update" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private CountryCurrency countryCurrency { get; set; }
    protected override async Task OnInitializedAsync()
    {
        countryCurrency ??= await repo.GetAsync(Id);
        if (countryCurrency is null) NavigationManager.NotFound();
    }
    private async Task update()
    {
        await repo.UpdateAsync(countryCurrency);
        NavigationManager.NavigateTo("/countrycurrencies");
    }
}
