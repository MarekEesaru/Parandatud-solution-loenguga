@page "/countrycurrencies/details"
@attribute [ExcludeFromInteractiveRouting]
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage PageTitleText="Country Currencies Details" EntityTitle="Country Currency" BasePath="/countrycurrencies" Entity="item" EntityId="item?.Id" />

@code {
    private CountryCurrency item;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
}
