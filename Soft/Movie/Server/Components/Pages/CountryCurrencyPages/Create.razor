@page "/countrycurrencies/create"
@attribute [ExcludeFromInteractiveRouting]
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="item" EntityTitle="Country Currency" BasePath="/countrycurrencies" OnValidSubmit="add" />

@code {
    [SupplyParameterFromForm] private CountryCurrency item { get; set; } = default!;
    protected override void OnInitialized() => item ??= new();
    private async Task add() 
    {
        await repo.CreateAsync(item);
        NavigationManager.NavigateTo("/countrycurrencies");
    }
}
