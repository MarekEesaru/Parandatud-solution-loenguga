@page "/monies/details"
@attribute [ExcludeFromInteractiveRouting]
@inject IMoniesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage PageTitleText="Money Details" EntityTitle="Money" BasePath="/monies" Entity="item" EntityId="item?.Id" />

@code {
    private Money item;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
}
