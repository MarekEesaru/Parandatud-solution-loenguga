@page "/money/delete"
@attribute [ExcludeFromInteractiveRouting]
@inject IMoneyRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Money" EntityTitle="Money" BasePath="/money" Entity="item" OnValidSubmit="delete" />

@code {
    private Money item;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
    private async Task delete()
    {
        await repo.DeleteAsync(item!.Id);
        NavigationManager.NavigateTo("/money");
    }
}
