@page "/monies/edit"
@attribute [ExcludeFromInteractiveRouting]
@inject IMoniesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage PageTitleText="Edit Money" EntityTitle="Money" Entity="money" BasePath="/monies" EntityId="@Id" OnValidSubmit="update" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private Money money { get; set; }
    protected override async Task OnInitializedAsync()
    {
        money ??= await repo.GetAsync(Id);
        if (money is null) NavigationManager.NotFound();
    }
    private async Task update()
    {
        await repo.UpdateAsync(money);
        NavigationManager.NavigateTo("/monies");
    }
}
