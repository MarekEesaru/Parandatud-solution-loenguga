@page "/countries"
@attribute [ExcludeFromInteractiveRouting]
@inject NavigationManager NavigationManager
@inject ICountriesRepo repo

<MyIndexPage TItem="Country" PageTitleText="Countries" EntityTitle="Countries" Items="countries" BasePath="countries" />

@code {
    private IQueryable<Country> countries = Enumerable.Empty<Country>().AsQueryable();
    protected override async Task OnInitializedAsync() {
        if (repo is null) return;
        countries = (await repo.GetAsync()).AsQueryable();
    }
}
