@page "/countries/details"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Infra
@using Abc.Data
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage PageTitleText="Country Details"
               EntityTitle="Country"
               BasePath="/=countries"
               Entity="country"
               EntityId="country?.Id" />

@code {
    private Country country;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        country = await repo.GetAsync(Id);
        if (country is null) NavigationManager.NotFound();
    }
}
