@page "/countries/delete"
@attribute [ExcludeFromInteractiveRouting]
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Country" EntityTitle="Country" BasePath="/countries" Entity="item" OnValidSubmit="delete" />

@code {
    private Country item;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
    private async Task delete()
    {
        await repo.DeleteAsync(item!.Id);
        NavigationManager.NavigateTo("/countries");
    }
}
