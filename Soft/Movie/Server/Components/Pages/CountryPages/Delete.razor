@page "/countries/delete"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Infra
@using Abc.Data
@using Abc.Shared.Pages
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Country" EntityTitle="Country" BasePath="/countries" Entity="country" EntityId="country?.Id" OnValidSubmit="deleteCountry" />

@code {
    private Country country;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        country = await repo.GetAsync(Id);
        if (country is null) NavigationManager.NotFound();
    }
    private async Task deleteCountry()
    {
        await repo.DeleteAsync(country!.Id);
        NavigationManager.NavigateTo("/countries");
    }
}
