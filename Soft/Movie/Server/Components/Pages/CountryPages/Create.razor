@page "/countries/create"
@attribute [ExcludeFromInteractiveRouting]
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="item" EntityTitle="Country" BasePath="/countries" OnValidSubmit="add" />

@code {
    [SupplyParameterFromForm(Name = nameof(Country))] private Country item { get; set; } = default!;
    protected override void OnInitialized() => item ??= new();
    private async Task add()
    {
        await repo.CreateAsync(item);
        NavigationManager.NavigateTo("/countries");
    }
}
