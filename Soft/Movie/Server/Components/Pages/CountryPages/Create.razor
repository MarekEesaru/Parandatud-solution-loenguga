@page "/countries/create"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Infra
@using Abc.Data
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<PageTitle>Create Country</PageTitle>

<h1>Create</h1>

<h2>Country</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="country" OnValidSubmit="addCountry" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <MyEntityEditor Entity="country" />
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/countries">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm] private Country country { get; set; } = default!;
    protected override void OnInitialized() => country ??= new();
    private async Task addCountry()
    {
        await repo.CreateAsync(country);
        NavigationManager.NavigateTo("/countries");
    }
}
