@page "/countries/edit"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Infra
@using Abc.Data
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<PageTitle>Edit Country</PageTitle>

<h1>Edit</h1>

<h2>Country</h2>
<hr />
@if (country is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="country" OnValidSubmit="updateCountry" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="country.Id" value="@country.Id" />
                <MyEntityEditor Entity="country" />
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}
<div>
    <a href="/countries">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private Country country { get; set; }
    protected override async Task OnInitializedAsync()
    {
        country ??= await repo.GetAsync(Id);
        if (country is null) NavigationManager.NotFound();
    }
    private async Task updateCountry()
    {
        await repo.UpdateAsync(country);
        NavigationManager.NavigateTo("/countries");
    }
}
