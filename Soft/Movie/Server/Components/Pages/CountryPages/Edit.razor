@page "/countries/edit"
@attribute [ExcludeFromInteractiveRouting]
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage PageTitleText="Edit Country" EntityTitle="@item?.Name" Entity="item" BasePath="/countries" EntityId="@Id" OnValidSubmit="update" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm(Name = nameof(Country))] private Country item { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item ??= await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
    private async Task update()
    {
        await repo.UpdateAsync(item);
        NavigationManager.NavigateTo("/countries");
    }
}
