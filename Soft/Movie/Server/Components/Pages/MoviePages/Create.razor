@page "/movies/create"
@attribute [ExcludeFromInteractiveRouting]
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="item" EntityTitle="Movie" BasePath="/movies" OnValidSubmit="add" />

@code {
    [SupplyParameterFromForm] private Movie item { get; set; } = default!;
    protected override void OnInitialized() => item ??= new();
    private async Task add() 
    {
        await repo.CreateAsync(item);
        NavigationManager.NavigateTo("/movies");
    }
}
