@page "/movies/edit"
@attribute [ExcludeFromInteractiveRouting]
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage PageTitleText="Edit Movie" EntityTitle="@item?.Name" Entity="item" BasePath="/movies" EntityId="@Id" OnValidSubmit="update" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private Movie item { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item ??= await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
    private async Task update()
    {
        await repo.UpdateAsync(item);
        NavigationManager.NavigateTo("/movies");
    }
}
