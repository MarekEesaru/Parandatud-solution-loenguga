@page "/movies/details"
@attribute [ExcludeFromInteractiveRouting]
@using Abc.Infra
@using Abc.Data
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage PageTitleText="Movie Details"
               EntityTitle="Movie"
               BasePath="/movies"
               Entity="movie"
               EntityId="movie?.Id" />

@code {
    private Movie movie;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        movie = await repo.GetAsync(Id);
        if (movie is null) NavigationManager.NotFound();
    }
}
