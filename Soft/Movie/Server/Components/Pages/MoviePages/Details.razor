@page "/movies/details"
@attribute [ExcludeFromInteractiveRouting]
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage PageTitleText="Movie Details" EntityTitle="Movie" BasePath="/movies" Entity="item" EntityId="item?.Id" />

@code {
    private Movie item;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
}
