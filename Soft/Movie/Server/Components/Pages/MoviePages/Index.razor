@page "/movies"
@attribute [ExcludeFromInteractiveRouting]
@inject NavigationManager NavigationManager
@inject IMoviesRepo repo

<MyIndexPage TItem="Movie" PageTitleText="Movies" EntityTitle="Movies" Items="movies" BasePath="movies" />

@code {
    private IQueryable<Movie> movies = Enumerable.Empty<Movie>().AsQueryable();
    protected override async Task OnInitializedAsync()
    {
        if (repo is null) return;
        movies = (await repo.GetAsync()).AsQueryable();
    }
}
