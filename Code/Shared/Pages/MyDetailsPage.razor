<PageTitle>@PageTitleText</PageTitle>

<h1>Details</h1>

<div>
    <h2>@EntityTitle</h2>
    <hr />
    @if (Entity is null) {
        <p><em>Loading...</em></p>
    } else {
        @if (ChildContent is not null) {
            @ChildContent
        } else {
            <MyEntityViewer Entity="Entity" />
        }
        <dl class="row"></dl>
        <div>
            <a href="@($"{BasePath}/edit?id={EntityId}")">Edit</a> |
            <a href="@BasePath">Back to List</a>
        </div>
    }
</div>
@code {
    [Parameter] public string PageTitleText { get; set; } = "Details";
    [Parameter] public string EntityTitle { get; set; }
    [Parameter] public string BasePath { get; set; }
    [Parameter] public object Entity { get; set; }
    [Parameter] public Guid? EntityId { get; set; }
    [Parameter] public RenderFragment ChildContent { get; set; }
}
