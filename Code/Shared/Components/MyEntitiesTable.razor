@typeparam TEntity where TEntity : BaseEntity
<QuickGrid Class="table myTable" Items="Entities">
    @foreach (var p in typeof(TEntity).GetProperties())
    {
        @if (!show(p)) continue;
        <TemplateColumn>
            <HeaderTemplate>
                <div class="header-stack">
                    <a href="@headerHref(p.Name)">@iconed(p.Name)</a>
                    <form method="get" action="">
                        <input type="hidden" name="sortDir" value="asc" />
                        <input type="hidden" name="pageSize" value="7" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="sortBy" value="@p.Name" />
                        <input type="search" class="form-control form-control-sm"
                               name="search" value="" disabled="" placeholder="Search..." />
                    </form>
                </div>
            </HeaderTemplate>
            <ChildContent Context="y">
                @(value(p, y))
            </ChildContent>
        </TemplateColumn>
    }
    <TemplateColumn Context="y">
        <a href="@($"{BasePath}/edit?id={y.Id}")">Edit</a> |
        <a href="@($"{BasePath}/details?id={y.Id}")">Details</a> |
        <a href="@($"{BasePath}/delete?id={y.Id}")">Delete</a>
    </TemplateColumn>
</QuickGrid>

<MyTablePageNav Query="@query" TotalCount="@totalCount" CurrentUri="@nav.Uri" />

@code {
    private IQueryable<TEntity> Entities { get; set; }
    [Parameter] public IRepo<TEntity> Repo { get; set; }
    [Parameter] public string BasePath { get; set; }
    [Inject] private NavigationManager nav { get; set; }
    private int totalCount;
    private Query query;
    private string icon => query?.SortDir == "asc" ? " ▲" : query?.SortDir == "desc" ? " ▼" : string.Empty;
    private string iconed(string name) => (query?.SortBy == name) ? name + icon : name;
    protected override async Task OnInitializedAsync()
    {
        if (Repo is null) return;
        var uri = nav.ToAbsoluteUri(nav.Uri);
        query = new UrlParams(uri).Parse();
        totalCount = await Repo.CountAsync(query);
        Entities = (await Repo.GetAsync(query)).AsQueryable();
    }
    private string value(PropertyInfo p, TEntity e){
        var v = p?.GetValue(e);
        return v?.ToString() ?? string.Empty;
    }
    private bool show(PropertyInfo p){
        if (p is null) return false;
        if (p.Name == nameof(NamedEntity.Id)) return false;
        var t = p?.PropertyType;
        if (t == typeof(string)) return true;
        if (typeof(IEnumerable).IsAssignableFrom(t)) return false;
        if (t.IsClass) return false;
        return true;
    }
    private string headerHref(string name)
    {
        var n = ((query?.SortBy == name) && (query?.SortDir == "desc")) ? null : name;
        var d = query?.SortBy != name ? "asc" : "desc";
        var r = $"{BasePath}?Page=1&PageSize={query?.PageSize ?? 7}";
        return (n is null) ? r : r + $"&SortBy={n}&SortDir={d}";
    }
}

<style>
    .myTable {
        table-layout: fixed;
        width: 100%;
        max-width: 100%;
    }

        .myTable td {
            white-space: normal;
            overflow-wrap: anywhere;
            word-break: break-word;
        }
</style>
