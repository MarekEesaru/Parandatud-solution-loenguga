@typeparam TEntity where TEntity : BaseEntity
<MyQuickGrid TEntity="TEntity" Repo="@Repo" Entities="@Entities" BasePath="@BasePath" Query="@query"/>
@if (isSelected(selectedItem))
{
    foreach (var c in new RelatedLists(selectedItem))
    {
        var items = c.Items;
        var cols = c.Properties;
        <div class="panel">
            <div class="header">
                <span>@c.Name (@c.Count)</span>
                <a href="@closHref(selectedItem)" aria-label="Close" class="close">×</a>
            </div>
            <QuickGrid Class="table myTable" Items="items">
                @foreach (var p in cols)
                {
                    @if (!show(p)) continue;
                    <TemplateColumn>
                        <HeaderTemplate>@p.Name</HeaderTemplate>
                        <ChildContent Context="y">
                            @(p.GetValue(y)?.ToString() ?? string.Empty)
                        </ChildContent>
                    </TemplateColumn>
                }
            </QuickGrid>
        </div>
    }
}
@if (Others.Any())
{
    <MyQuickGrid TEntity="TEntity" Repo="@Repo" Entities="@Others" BasePath="@BasePath" Query="@query" ShowHeader="@false"/>
}
<MyTablePageNav Query="@query" TotalCount="@totalCount" CurrentUri="@nav.Uri" />

@code {
    private IQueryable<TEntity> Entities { get; set; }
    private IQueryable<TEntity> Others { get; set; }
    [Parameter] public IRepo<TEntity> Repo { get; set; }
    [Parameter] public string BasePath { get; set; }
    [Inject] private NavigationManager nav { get; set; }
    private int totalCount;
    private Query query;
    private TEntity selectedItem;
    protected override async Task OnInitializedAsync()
    {
        if (Repo is null) return;
        var uri = nav.ToAbsoluteUri(nav.Uri);
        query = new UrlParams(uri).Parse();
        totalCount = await Repo.CountAsync(query);
        var toOthers = false;
        var entities = new List<TEntity>();
        var others = new List<TEntity>();
        var all = (await Repo.GetAsync(query)).ToList();
        foreach (var e in all)
        {
            if (toOthers)
            {
                others.Add(e);
                continue;
            }
            entities.Add(e);
            if (e.Id.ToString() != query.Selected) toOthers = true;
            toOthers = true;
            selectedItem = e;
        }
        Entities = entities.AsQueryable();
        Others = others.AsQueryable();
    }
    private bool isSelected(TEntity e) => query.Selected == e?.Id.ToString();
    private string closHref(TEntity e) => query.Href(BasePath, e.Id);
    private bool show(PropertyInfo p)
    {
        if (p is null) return false;
        if (p.Name == nameof(NamedEntity.Id)) return false;
        var t = p?.PropertyType;
        if (t == typeof(string)) return true;
        if (typeof(IEnumerable).IsAssignableFrom(t)) return false;
        if (t.IsClass) return false;
        return true;
    }
}
